                  "OWASP a1-injection",
                  "ng-sast"
                ]
              },
              "shortDescription": {
                "text": "Insecure Direct Object Reference: Attacker-controlled Data Used Directly to Find Database Entry in AccountController.getAccount via accountId "
              }
