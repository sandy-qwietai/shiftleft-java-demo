            {
              "defaultConfiguration": {
                "enabled": true,
                "level": "error",
                "rank": -1
              },
              "fullDescription": {
                "text": "FasterXML jackson-databind 2.x before 2.9.7 might allow remote attackers to conduct server-side request forgery (SSRF) attacks by leveraging failure to block the axis2-jaxws class from polymorphic deserialization."
              },
              "help": {
                "markdown": "FasterXML jackson-databind 2.x before 2.9.7 might allow remote attackers to conduct server-side request forgery (SSRF) attacks by leveraging failure to block the axis2-jaxws class from polymorphic deserialization.",
                "text": "FasterXML jackson-databind 2.x before 2.9.7 might allow remote attackers to conduct server-side request forgery (SSRF) attacks by leveraging failure to block the axis2-jaxws class from polymorphic deserialization."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/918.html",
              "id": "oss_vuln/1b36fb5d44e921c8d81032023ba1a013",
              "name": "Pkg:maven/Com.fasterxml.jackson.core/Jackson-Databind@2.8.6",
              "properties": {
                "precision": "very-high",
                "security-severity": "10",
                "tags": [
                  "CVE-2018-14721",
                  "CVSS 10",
                  "CWE 918",
                  "No exploits",
                  "Unreachable",
