              "helpUri": "https://owasp.org/www-project-top-ten/OWASP_Top_Ten_2017/Top_10-2017_a2-Broken_Authentication",
              "id": "hash-compare/527232c0c5d90b49ddeef47dd41ffb7b",
              "name": "Timing Attack: Observable Timing Discrepancy In Comparison Of Cryptographic Hashes In Customercontroller.savesettings",
              "properties": {
                "precision": "very-high",
                "security-severity": "5",
                "tags": [
                  "CVSS 5",
                  "CWE 208",
                  "OWASP 2021 a07-identification-and-authentication-failures",
                  "OWASP a07-2021-identification-and-authentication-failures",
