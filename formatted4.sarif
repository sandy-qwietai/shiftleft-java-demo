              "name": "Cross-Site Scripting: Attacker-Controlled Data Used As Html Content Via Phonenumber In Customercontroller.debug",
              "properties": {
                "precision": "very-high",
                "security-severity": "8",
                "tags": [
                  "CVSS 8",
                  "CWE 79",
